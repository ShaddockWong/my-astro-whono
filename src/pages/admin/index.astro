    toggleBtn.setAttribute('title', visible ? `隐藏 ${label}` : `恢复 ${label}`);
  };
  const normalizeSocialOrders = () => {
    const presetRows = getPresetRows();
    const customRows = getCustomRows();
    const items = [
      ...presetRows.map((row, index) => ({
        row,
        type: 'preset',
        visible: isPresetRowVisible(row),
        order: parseOrder(
          getPresetRowOrderInput(row)?.value || '',
          SOCIAL_PRESET_DEFAULT_ORDER[getPresetRowId(row)]
        ),
        tie: index
      })),
      ...customRows.map((row, index) => ({
        row,
        type: 'custom',
        visible: Boolean(row.querySelector('[data-social-custom-field="visible"]')?.checked),
        order: parseOrder(row.querySelector('[data-social-custom-field="order"]')?.value || '', index + 1),
        tie: presetRows.length + index
      }))
    ];
    const orderedItems = [
      ...items.filter((item) => item.visible).sort((a, b) => a.order - b.order || a.tie - b.tie),
      ...items.filter((item) => !item.visible).sort((a, b) => a.order - b.order || a.tie - b.tie)
    ];

    orderedItems.forEach((item, index) => {
      const nextValue = String(index + 1);
      if (item.type === 'preset') {
        const orderInput = getPresetRowOrderInput(item.row);
        if (orderInput instanceof HTMLInputElement) orderInput.value = nextValue;
      } else {
        const orderInput = item.row.querySelector('[data-social-custom-field="order"]');
        if (orderInput instanceof HTMLInputElement) orderInput.value = nextValue;
      }
    });
  };

  const slugifyIdPart = (value) => {
    const slug = String(value ?? '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
    return slug || 'link';
  };

  const getCustomIdValues = (exceptRow) =>
    new Set(
      getCustomRows()
        .filter((row) => row !== exceptRow)
        .map((row) => row.querySelector('[data-social-custom-field="id"]')?.value.trim())
        .filter(Boolean)
    );

  const generateCustomId = (row, iconKey = getCustomRowIconKey(row)) => {
    const existingIds = getCustomIdValues(row);
    const base = `custom-${slugifyIdPart(iconKey)}`;
    let candidate = base;
    let suffix = 2;

    while (existingIds.has(candidate)) {
      candidate = `${base}-${suffix}`;
      suffix += 1;
    }

    return candidate;
  };

  const getStoredGeneratedCustomId = (row) => row?.dataset.generatedId?.trim() || '';

  const applyGeneratedCustomId = (row, nextId) => {
