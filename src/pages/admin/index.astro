---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { getThemeSettings, type SidebarNavId, type SiteSocialIconKey, type SiteSocialPresetId } from '../../lib/theme-settings';
import { createWithBase } from '../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const settingsEndpoint = withBase('/api/admin/settings/');

const navIdOrder: SidebarNavId[] = ['essay', 'bits', 'memo', 'archive', 'about'];
const navLabelFallback: Record<SidebarNavId, string> = {
  essay: '随笔',
  bits: '絮语',
  memo: '小记',
  archive: '归档',
  about: '关于'
};
const homeIntroMaxLength = 240;
const pageSubtitleMaxLength = 120;
const footerStartYearMin = 1900;
const footerStartYearMax = new Date().getFullYear();
const socialCustomLimit = 8;
const defaultCustomSocialIconKey: SiteSocialIconKey = 'website';
const socialIconOptions: readonly {
  value: SiteSocialIconKey;
  optionLabel: string;
  savedLabel: string;
}[] = [
  { value: 'github', optionLabel: 'GitHub', savedLabel: 'GitHub' },
  { value: 'x', optionLabel: 'X', savedLabel: 'X' },
  { value: 'email', optionLabel: 'Email', savedLabel: 'Email' },
  { value: 'weibo', optionLabel: '微博', savedLabel: '微博' },
  { value: 'facebook', optionLabel: 'Facebook', savedLabel: 'Facebook' },
  { value: 'instagram', optionLabel: 'Instagram', savedLabel: 'Instagram' },
  { value: 'telegram', optionLabel: 'Telegram', savedLabel: 'Telegram' },
  { value: 'mastodon', optionLabel: 'Mastodon', savedLabel: 'Mastodon' },
  { value: 'bilibili', optionLabel: 'Bilibili', savedLabel: 'Bilibili' },
  { value: 'youtube', optionLabel: 'YouTube', savedLabel: 'YouTube' },
  { value: 'linkedin', optionLabel: 'LinkedIn', savedLabel: 'LinkedIn' },
  { value: 'website', optionLabel: '网站', savedLabel: '网站' },
  { value: 'link', optionLabel: '链接', savedLabel: '链接' },
  { value: 'globe', optionLabel: '站点', savedLabel: '站点' }
];
const customSocialIconOptions = socialIconOptions.filter(
  (option) => option.value !== 'github' && option.value !== 'x' && option.value !== 'email'
);
const socialPresetRows = [
  {
    id: 'github' as SiteSocialPresetId,
    label: 'GitHub',
    orderInputId: 'site-social-github-order',
    inputId: 'site-social-github',
    inputType: 'url',
    inputMode: 'url',
    autoComplete: 'url',
    placeholder: 'https://github.com/username'
  },
  {
    id: 'x' as SiteSocialPresetId,
    label: 'X',
    orderInputId: 'site-social-x-order',
    inputId: 'site-social-x',
    inputType: 'url',
    inputMode: 'url',
    autoComplete: 'url',
    placeholder: 'https://x.com/username'
  },
  {
    id: 'email' as SiteSocialPresetId,
    label: 'Email',
    orderInputId: 'site-social-email-order',
    inputId: 'site-social-email',
    inputType: 'email',
    inputMode: 'email',
    autoComplete: 'email',
    placeholder: 'name@example.com'
  }
] as const;

const initialResolved = getThemeSettings();
const initialNavMap = new Map(
  initialResolved.settings.shell.nav.map((item) => [item.id, item])
);

const initialPayload = {
  settings: {
    ...initialResolved.settings,
    shell: {
      ...initialResolved.settings.shell,
      nav: navIdOrder.map((id, index) => {
        const current = initialNavMap.get(id);
        if (current) return current;
        return {
          id,
          label: navLabelFallback[id],
          visible: true,
          order: index + 1
        };
      })
    }
  },
  sources: initialResolved.sources
};

const bootstrapJson = JSON.stringify(initialPayload).replace(/</g, '\u003c');
---

<BaseLayout title="Theme Console" bodyClass="admin-page">
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  {
    isDev ? (
      <section class="admin-console" data-admin-root data-settings-endpoint={settingsEndpoint}>
        <header class="page-header page-header--admin">
          <div class="admin-heading">
            <h1 class="page-title">Theme Console</h1>
            <span class="page-subtitle">主题设置</span>
          </div>
          <p id="admin-status" class="admin-status" data-state="idle">等待加载</p>
        </header>

        <p class="admin-hint">
          当前阶段仅开放受约束字段：<code>site</code> / <code>shell</code> / <code>home</code> /
          <code>page</code> / <code>ui</code>。保存后会写入 <code>src/data/settings/*.json</code>。
        </p>

        <p id="admin-dirty-banner" class="admin-banner" hidden>你有未保存更改，离开页面会触发提醒。</p>
        <p id="admin-error-banner" class="admin-banner admin-banner--error" hidden></p>

        <form id="admin-form" class="admin-form" novalidate>
          <fieldset class="admin-group">
            <legend class="admin-group__legend">
              <span class="admin-group__legend-zh">站点设置</span>
              <span class="admin-group__legend-sep" aria-hidden="true">·</span>
              <span class="admin-group__legend-en">Site</span>
            </legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">站点标题</span>
                  <span class="admin-label__hint">（用于浏览器标题 / RSS / 分享）</span>
                </span>
                <input id="site-title" type="text" autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">默认语言</span>
                  <span class="admin-label__hint">（映射到 <code>&lt;html lang&gt;</code>）</span>
                </span>
                <input id="site-default-locale" type="text" autocomplete="off" />
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">默认 SEO 描述</span>
                  <span class="admin-label__hint">（用于未单独设置 description 的页面）</span>
                </span>
                <textarea id="site-description" rows="3"></textarea>
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">页脚年份</span>
                  <span class="admin-label__hint">（结束年份自动拾取当前年）</span>
                </span>
                <span class="admin-year-range">
                  <input
                    id="site-footer-start-year"
                    type="number"
                    min={footerStartYearMin}
                    max={footerStartYearMax}
                    step="1"
                    inputmode="numeric"
                    placeholder={String(footerStartYearMax)}
                    aria-describedby="site-footer-preview"
                  />
                  <span class="admin-year-range__sep" aria-hidden="true">-</span>
                  <input
                    class="admin-year-range__readonly"
                    type="text"
                    value={String(footerStartYearMax)}
                    readonly
                    tabindex="-1"
                    aria-label="当前年份（自动）"
                  />
                  <label class="admin-year-range__toggle">
                    <input id="site-footer-show-current-year" type="checkbox" checked />
                    <span class="sr-only">显示当前年</span>
                  </label>
                </span>
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">页脚版权文案</span>
                </span>
                <input id="site-footer-copyright" type="text" autocomplete="off" aria-describedby="site-footer-preview" />
              </label>
              <div class="admin-field admin-field--full">
                <p id="site-footer-preview" class="admin-help">
                  页脚预览：<code id="site-footer-preview-value">© {footerStartYearMax} Whono · Theme Demo · by cxro</code>
                </p>
              </div>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">
                <span class="admin-subtitle__main">社交链接</span>
                <span class="admin-subtitle__hint">（固定平台 + 可新增链接）</span>
              </p>
              <div class="admin-social-panel">
                <div class="admin-social-panel__head">
                  <p class="admin-subtitle admin-subtitle--compact">
                    <span class="admin-subtitle__main">链接列表</span>
                    <span class="admin-subtitle__hint">（可继续新增 GitHub / X / Email 之外的平台，最多 {socialCustomLimit} 条）</span>
                  </p>
                  <p id="site-social-custom-count" class="admin-help">新增 0 / {socialCustomLimit}</p>
                </div>
                <p class="admin-help">
                  about 页的 RSS 入口仍由前台固定输出；固定平台留空即隐藏，位置排序会与扩展链接一起参与统一排序。
                </p>
                <p id="site-social-custom-empty" class="admin-social-empty">
                  当前只有 GitHub / X / Email。可继续新增微博、Bilibili、个人站点等链接。
                </p>
                <div class="admin-social-table">
                  <div id="site-social-custom-head" class="admin-social-header" aria-hidden="true">
                    <span>位置</span>
                    <span>平台</span>
                    <span>链接代号</span>
                    <span>图标</span>
                    <span>链接地址</span>
                    <span>操作</span>
                  </div>
                  <div id="site-social-custom-list" class="admin-social-list">
                    {
                      socialPresetRows.map((row) => (
                        <article class="admin-social-row admin-social-row--preset" data-social-preset-row data-social-preset-id={row.id}>
                          <label class="admin-field admin-social-field admin-social-field--order">
                            <span class="admin-social-cell-label">位置</span>
                            <span class="admin-social-order-frame">
                              <span class="admin-social-order-frame__mark" aria-hidden="true">[</span>
                              <input
                                id={row.orderInputId}
                                data-social-preset-field="order"
                                type="number"
                                min="1"
                                max="999"
                                step="1"
                                inputmode="numeric"
                                aria-label={`${row.label} 位置排序`}
                              />
                              <span class="admin-social-order-frame__mark" aria-hidden="true">]</span>
                            </span>
                          </label>

                          <div class="admin-field admin-social-field admin-social-field--platform admin-social-field--static">
                            <span class="admin-social-cell-label">平台</span>
                            <input class="admin-social-static-input" type="text" value={row.label} readonly tabindex="-1" />
                          </div>

                          <div class="admin-field admin-social-field admin-social-field--id admin-social-field--static">
                            <span class="admin-social-cell-label">链接代号</span>
                            <input
                              class="admin-social-static-input admin-social-static-input--code"
                              type="text"
                              value={row.id}
                              readonly
                              tabindex="-1"
                            />
                          </div>

                          <div class="admin-social-field admin-social-field--icon admin-social-field--static">
                            <span class="admin-social-cell-label">图标</span>
                            <div class="admin-social-icon-preview">
                              <span class="admin-social-icon-only">
                                <Icon name={row.id} class="admin-social-icon-only__icon" size={16} />
                              </span>
                            </div>
                          </div>

                          <label class="admin-field admin-social-field admin-social-field--href">
                            <span class="admin-social-cell-label">{row.id === 'email' ? '邮箱地址' : '链接地址'}</span>
                            <input
                              id={row.inputId}
                              data-social-preset-field="href"
                              type={row.inputType}
                              inputmode={row.inputMode}
                              autocomplete={row.autoComplete}
                              placeholder={row.placeholder}
                            />
                          </label>

                          <div class="admin-field admin-social-field admin-social-field--actions admin-social-field--static">
                            <span class="admin-social-cell-label">操作</span>
                            <div class="admin-social-row-actions">
                              <button
                                class="admin-social-action"
                                type="button"
                                data-social-preset-action="toggle-visible"
                                aria-pressed="true"
                                aria-label={`隐藏 ${row.label}`}
                                title={`隐藏 ${row.label}`}
                              >
                                <Icon name="eye" class="admin-social-action__icon" size={15} />
                                <span class="sr-only">{`隐藏 ${row.label}`}</span>
                              </button>
                              <button
                                class="admin-social-action admin-social-action--disabled"
                                type="button"
                                data-social-preset-action="remove"
                                aria-label={`${row.label} 为固定项，不可删除`}
                                title={`${row.label} 为固定项，不可删除`}
                                disabled
                              >
                                <Icon name="trash" class="admin-social-action__icon" size={15} />
                                <span class="sr-only">{`${row.label} 为固定项，不可删除`}</span>
                              </button>
                            </div>
                          </div>
                        </article>
                      ))
                    }
                  </div>
                </div>
                <div class="admin-social-actions">
                  <button id="site-social-custom-add" class="admin-btn admin-btn--ghost" type="button">
                    新增链接
                  </button>
                </div>
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend class="admin-group__legend">
              <span class="admin-group__legend-zh">侧栏设置</span>
              <span class="admin-group__legend-sep" aria-hidden="true">·</span>
              <span class="admin-group__legend-en">Sidebar</span>
            </legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">侧栏站点名</span>
                  <span class="admin-label__hint">（显示在左侧站点标题）</span>
                </span>
                <input id="shell-brand-title" type="text" autocomplete="off" />
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">侧栏引用文案</span>
                  <span class="admin-label__hint">（支持换行显示）</span>
                </span>
                <textarea id="shell-quote" rows="4"></textarea>
              </label>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">
                <span class="admin-subtitle__main">侧栏导航</span>
                <span class="admin-subtitle__hint">（仅既有项）</span>
              </p>
              <div class="admin-nav-grid">
                <div class="admin-nav-header" aria-hidden="true">
                  <span>页面 ID</span>
                  <span>页面名称</span>
                  <span>位置排序</span>
                  <span>是否展示</span>
                </div>
                {
                  navIdOrder.map((id, index) => (
                    <div class="admin-nav-row" data-nav-id={id}>
                      <p class="admin-nav-id">
                        <span class="admin-nav-cell-label">页面 ID</span>
                        <code>{id}</code>
                      </p>
                      <label class="admin-field admin-nav-field admin-nav-field--name">
                        <span class="admin-nav-cell-label">页面名称</span>
                        <span class="sr-only">{id} 页面名称</span>
                        <span class="admin-nav-name-frame">
                          <span class="admin-nav-name-frame__mark" aria-hidden="true">&lt;</span>
                          <input data-nav-field="label" type="text" autocomplete="off" />
                          <span class="admin-nav-name-frame__mark" aria-hidden="true">&gt;</span>
                        </span>
                      </label>
                      <label class="admin-field admin-nav-field admin-nav-field--order">
                        <span class="admin-nav-cell-label">位置排序</span>
                        <span class="sr-only">{id} 位置排序</span>
                        <input data-nav-field="order" type="number" min="1" step="1" value={index + 1} />
                      </label>
                      <label class="admin-toggle">
                        <span class="admin-nav-cell-label">是否展示</span>
                        <span class="admin-toggle__control">
                          <input data-nav-field="visible" type="checkbox" aria-label={`${id} 是否显示`} />
                        </span>
                      </label>
                    </div>
                  ))
                }
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend class="admin-group__legend">
              <span class="admin-group__legend-zh">首页设置</span>
              <span class="admin-group__legend-sep" aria-hidden="true">·</span>
              <span class="admin-group__legend-en">Home</span>
            </legend>
            <div class="admin-grid">
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">首页导语主文案</span>
                </span>
                <textarea id="home-intro-lead" rows="3" maxlength={homeIntroMaxLength}></textarea>
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">首页导语补充文案</span>
                  <span class="admin-label__hint">（后方固定附带归档 / 随笔链接）</span>
                </span>
                <textarea id="home-intro-more" rows="2" maxlength={homeIntroMaxLength}></textarea>
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">Hero 预置</span>
                </span>
                <select id="home-hero-preset">
                  <option value="default">default</option>
                  <option value="minimal">minimal</option>
                  <option value="none">none</option>
                </select>
              </label>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend class="admin-group__legend">
              <span class="admin-group__legend-zh">内页设置</span>
              <span class="admin-group__legend-sep" aria-hidden="true">·</span>
              <span class="admin-group__legend-en">Inner pages</span>
            </legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">随笔副标题</span>
                  <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
                </span>
                <input id="page-essay-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">归档副标题</span>
                  <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
                </span>
                <input id="page-archive-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">絮语副标题</span>
                </span>
                <input id="page-bits-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">小记副标题</span>
                  <span class="admin-label__hint">（留空则回退 memo frontmatter）</span>
                </span>
                <input id="page-memo-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">关于页副标题</span>
                  <span class="admin-label__hint">（可留空）</span>
                </span>
                <input id="page-about-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">
                <span class="admin-subtitle__main">Bits 默认作者</span>
              </p>
              <div class="admin-grid">
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">默认作者名</span>
                  </span>
                  <input id="page-bits-author-name" type="text" autocomplete="off" />
                </label>
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">默认头像</span>
                    <span class="admin-label__hint">（相对路径）</span>
                  </span>
                  <input id="page-bits-author-avatar" type="text" autocomplete="off" />
                </label>
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend class="admin-group__legend">
              <span class="admin-group__legend-zh">阅读与代码</span>
              <span class="admin-group__legend-sep" aria-hidden="true">·</span>
              <span class="admin-group__legend-en">Reading / code</span>
            </legend>
            <div class="admin-stack">
              <label class="admin-toggle-row">
                <input id="ui-code-line-numbers" type="checkbox" />
                <span>显示代码行号（仅映射全局 data-line-numbers）</span>
              </label>
              <label class="admin-toggle-row">
                <input id="ui-reading-entry" type="checkbox" />
                <span>显示阅读模式入口（不改变“状态不持久化”策略）</span>
              </label>
            </div>
          </fieldset>
        </form>

        <div class="admin-actions">
          <button id="admin-validate" class="admin-btn" type="button">检查配置</button>
          <button id="admin-reset" class="admin-btn admin-btn--ghost" type="button">重置更改</button>
          <button id="admin-save" class="admin-btn admin-btn--muted" type="button">保存</button>
        </div>

        <template id="site-social-custom-row-template">
          <article class="admin-social-row" data-social-custom-row>
            <label class="admin-field admin-social-field admin-social-field--order">
              <span class="admin-social-cell-label">位置</span>
              <span class="admin-social-order-frame">
                <span class="admin-social-order-frame__mark" aria-hidden="true">[</span>
                <input data-social-custom-field="order" type="number" min="1" step="1" inputmode="numeric" />
                <span class="admin-social-order-frame__mark" aria-hidden="true">]</span>
              </span>
            </label>

            <label class="admin-field admin-social-field admin-social-field--platform">
              <span class="admin-social-cell-label">平台</span>
              <select data-social-custom-field="iconKey">
                {
                  customSocialIconOptions.map((option) => (
                    <option value={option.value} data-social-label={option.savedLabel}>
                      {option.optionLabel}
                    </option>
                  ))
                }
              </select>
            </label>

            <label class="admin-field admin-social-field admin-social-field--id">
              <span class="admin-social-cell-label">链接代号</span>
              <input data-social-custom-field="id" type="text" autocomplete="off" spellcheck="false" />
            </label>

            <div class="admin-social-field admin-social-field--icon">
              <span class="admin-social-cell-label">图标</span>
              <div class="admin-social-icon-preview" data-social-custom-icon-preview>
                {
                  socialIconOptions.map((option) => (
                    <span
                      class="admin-social-icon-only"
                      data-social-custom-icon-option={option.value}
                      hidden={option.value !== defaultCustomSocialIconKey}
                    >
                      <Icon name={option.value} class="admin-social-icon-only__icon" size={16} />
                    </span>
                  ))
                }
              </div>
            </div>

            <label class="admin-field admin-social-field admin-social-field--href">
              <span class="admin-social-cell-label">链接地址</span>
              <input data-social-custom-field="href" type="url" inputmode="url" autocomplete="off" placeholder="https://example.com" />
            </label>

            <div class="admin-social-field admin-social-field--actions">
