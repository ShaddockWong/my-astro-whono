  };

  const getPresetRowHrefInput = (row) => row?.querySelector('[data-social-preset-field="href"]');
  const getPresetRowOrderInput = (row) => row?.querySelector('[data-social-preset-field="order"]');
  const isPresetRowVisible = (row) => {
