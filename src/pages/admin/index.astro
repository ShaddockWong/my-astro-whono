    if (!(idInput instanceof HTMLInputElement)) return;

    idInput.value = nextId;
    row.dataset.generatedId = nextId;
    row.dataset.idManual = 'false';
  };

  const shouldAutoSyncCustomId = (row) => {
    const idInput = row?.querySelector('[data-social-custom-field="id"]');
    if (!(idInput instanceof HTMLInputElement)) return false;

    const trimmed = idInput.value.trim();
    const generatedId = getStoredGeneratedCustomId(row);

    return row?.dataset.idManual !== 'true' || !trimmed || (generatedId && trimmed === generatedId);
